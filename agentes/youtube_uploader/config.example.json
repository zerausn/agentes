{
    "audience_settings": {
        "selfDeclaredMadeForKids": false,
        "hasAlteredContentDisclosure": false
    },
    "default_metadata": {
        "categoryId": "24",
        "privacyStatus": "private",
        "description": "Video documental y de registro (Proyecto: [Nombre]).",
        "tags": ["teatro", "performance", "registro"],
        "license": "youtube"
    },
    "scheduling": {
        "colombia_time_offset": -5,
        "publish_hour": 17,
        "publish_minute": 45
    },
    "scanner": {
        "min_size_mb": 100,
        "video_extensions": [".mp4", ".mkv", ".avi", ".mov", ".wmv", ".flv"],
        "exclude_folders": [
            "windows", "program files", "appdata", ".git", "node_modules",
            "Temp", "Cache"
        ],
        "exclude_files": [
            "placeholder_video.mp4"
        ],
        "exclude_patterns": [
            "ScreenRecorderProject", "zoom_recording"
        ]
    }
}
